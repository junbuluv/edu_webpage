# Supabase --- create a project at https://supabase.com and paste the values here.
# Public anon key is safe to expose; never commit the service_role key.
PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="public-anon-key"
SUPABASE_SERVICE_ROLE_KEY="service-role-key-server-only"

# Used by `npm run supabase:types`
SUPABASE_PROJECT_REF="YOUR-PROJECT"

# Public site URL (used in auth redirects)
PUBLIC_SITE_URL="http://localhost:4321"

# Server-side secret used to HMAC PII (emails, IPs, user-agents) before
# storing them in the database. ≥32 chars. Generate with:
#   openssl rand -hex 32
# Rotate annually or on suspected compromise — see CONTRIBUTING.md.
PII_HMAC_SECRET="rotate-me-rotate-me-rotate-me-rotate-me-rotate"
