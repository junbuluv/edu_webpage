---
import type { StaffMetrics, TimeRange } from '@lib/staff-dashboard';
import type { CourseSlug } from '@lib/courses';

interface Props {
  metrics: StaffMetrics;
  courseSlug: CourseSlug;
  courseCode: string;
  range: TimeRange;
}

const { metrics, courseSlug, courseCode, range } = Astro.props;

const RANGE_LABELS: Record<TimeRange, string> = {
  week: 'this week',
  month: 'this month',
  all: 'all time',
};

const baseDashboardLink = `/dashboard?course=${courseSlug}`;
---

<section class="rounded-lg border border-amber-300 bg-amber-50 p-5">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <p class="text-xs uppercase tracking-wide font-medium text-amber-800">
        Course management — {courseCode}
      </p>
      <p class="mt-1 text-sm text-amber-900">
        Showing staff metrics for <strong>{RANGE_LABELS[range]}</strong>.
      </p>
    </div>
    <nav class="flex gap-1 text-xs" aria-label="Range">
      {
        (['week', 'month', 'all'] as TimeRange[]).map((r) => {
          const active = r === range;
          return (
            <a
              href={`${baseDashboardLink}&range=${r}`}
              class:list={[
                'rounded border px-2 py-0.5',
                active
                  ? 'border-amber-500 bg-amber-100 font-medium text-amber-900'
                  : 'border-amber-200 bg-white text-amber-800 hover:border-amber-400',
              ]}
            >
              {RANGE_LABELS[r]}
            </a>
          );
        })
      }
    </nav>
  </div>

  {
    !metrics && (
      <p class="mt-3 text-sm text-amber-900">
        No management view configured for this course yet.
      </p>
    )
  }

  {
    metrics?.kind === 'workshop' && (
      <div class="mt-4 space-y-4">
        <dl class="grid grid-cols-3 gap-3">
          <div class="rounded bg-white p-3">
            <dt class="text-xs uppercase tracking-wide text-amber-800">
              Stamps
            </dt>
            <dd class="mt-0.5 text-xl font-semibold">{metrics.totalStamps}</dd>
          </div>
          <div class="rounded bg-white p-3">
            <dt class="text-xs uppercase tracking-wide text-amber-800">
              Sessions touched
            </dt>
            <dd class="mt-0.5 text-xl font-semibold">
              {metrics.sessionsTouched}
            </dd>
          </div>
          <div class="rounded bg-white p-3">
            <dt class="text-xs uppercase tracking-wide text-amber-800">
              Open now
            </dt>
            <dd class="mt-0.5 text-xl font-semibold">{metrics.openNow}</dd>
          </div>
        </dl>

        {metrics.recent.length > 0 && (
          <div>
            <h3 class="text-sm font-semibold text-amber-900">Recent stamps</h3>
            <ul class="mt-2 divide-y divide-amber-200 rounded border border-amber-200 bg-white">
              {metrics.recent.map((s) => (
                <li class="flex flex-wrap items-center justify-between gap-2 px-3 py-2 text-xs">
                  <span class="font-medium">{s.section ?? '—'}</span>
                  <a
                    href={`/instructor/workshops/${s.workshop_slug}`}
                    class="text-accent underline"
                  >
                    {s.workshop_slug}
                  </a>
                  <code class="truncate text-ink-muted">{s.user_id}</code>
                  <span class="text-ink-muted">
                    {new Date(s.stamped_at).toLocaleString()}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        )}

        <p class="text-xs">
          <a href="/instructor/workshops" class="text-amber-900 underline">
            See all workshop sessions →
          </a>
        </p>
      </div>
    )
  }
</section>
