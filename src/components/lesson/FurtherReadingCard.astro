---
interface Props {
  article: {
    title: string;
    url: string;
    source: string;
    date?: string;
    why: string;
  };
  variant?: 'lesson' | 'quiz';
}

const { article, variant = 'lesson' } = Astro.props;

let domain: string;
try {
  domain = new URL(article.url).hostname.replace(/^www\./, '');
} catch {
  domain = article.source;
}

const heading =
  variant === 'quiz' ? 'Go one level deeper' : 'Read this next';
---

<aside
  class="my-10 overflow-hidden rounded-xl border-2 border-accent/40 bg-gradient-to-br from-accent/5 via-white to-white shadow-sm"
  aria-label="Recommended further reading"
>
  <div class="grid gap-0 md:grid-cols-[1fr_auto]">
    <div class="px-6 py-5">
      <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-accent">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
          <path d="M10.75 4.75a.75.75 0 0 0-1.5 0v4.5h-4.5a.75.75 0 0 0 0 1.5h4.5v4.5a.75.75 0 0 0 1.5 0v-4.5h4.5a.75.75 0 0 0 0-1.5h-4.5v-4.5Z" style="display:none" />
          <path fill-rule="evenodd" d="M2.232 12.207a.75.75 0 0 1 1.06.025l3.992 4.2 8.039-9.819a.75.75 0 1 1 1.16.95l-8.561 10.46a.75.75 0 0 1-1.085.04l-4.63-4.875a.75.75 0 0 1 .025-1.06Z" style="display:none" />
          <path fill-rule="evenodd" d="M10 2a.75.75 0 0 1 .75.75v.5h2.5a2.25 2.25 0 0 1 2.25 2.25v9A2.75 2.75 0 0 1 12.75 17h-5.5A2.75 2.75 0 0 1 4.5 14.25V5.5A2.25 2.25 0 0 1 6.75 3.25h2.5v-.5A.75.75 0 0 1 10 2ZM6.75 4.75a.75.75 0 0 0-.75.75v8.75c0 .69.56 1.25 1.25 1.25h5.5c.69 0 1.25-.56 1.25-1.25V5.5a.75.75 0 0 0-.75-.75H6.75ZM7.5 8a.75.75 0 0 1 .75-.75h3.5a.75.75 0 0 1 0 1.5h-3.5A.75.75 0 0 1 7.5 8Zm0 3a.75.75 0 0 1 .75-.75h3.5a.75.75 0 0 1 0 1.5h-3.5A.75.75 0 0 1 7.5 11Zm0 3a.75.75 0 0 1 .75-.75h2a.75.75 0 0 1 0 1.5h-2a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" />
        </svg>
        <span>{heading}</span>
      </div>

      <a
        href={article.url}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-3 block text-xl font-semibold leading-snug text-ink hover:text-accent hover:underline"
      >
        {article.title}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="ml-1 inline-block h-4 w-4 align-text-top text-accent">
          <path d="M11 3a.75.75 0 0 0 0 1.5h2.69L7.22 10.97a.75.75 0 1 0 1.06 1.06l6.47-6.47v2.69a.75.75 0 0 0 1.5 0V3h-5.25Z" />
          <path d="M3.5 6.75A1.75 1.75 0 0 1 5.25 5h2.25a.75.75 0 0 1 0 1.5H5.25a.25.25 0 0 0-.25.25v7.5c0 .14.11.25.25.25h7.5a.25.25 0 0 0 .25-.25v-2.25a.75.75 0 0 1 1.5 0v2.25A1.75 1.75 0 0 1 12.75 16h-7.5A1.75 1.75 0 0 1 3.5 14.25v-7.5Z" />
        </svg>
      </a>

      <p class="mt-3 text-sm leading-relaxed text-ink/80">{article.why}</p>
    </div>

    <div class="flex items-center justify-center border-t border-accent/20 bg-accent/10 px-6 py-4 md:border-l md:border-t-0 md:px-5">
      <div class="text-center">
        <div class="text-xs font-semibold uppercase tracking-wider text-accent">Source</div>
        <div class="mt-1 text-sm font-medium text-ink">{article.source}</div>
        {article.date && article.date !== 'undated' && (
          <div class="mt-1 text-xs text-ink-muted">{article.date}</div>
        )}
        <div class="mt-1 font-mono text-xs text-ink-muted">{domain}</div>
      </div>
    </div>
  </div>
</aside>
