---
import type { RosterStudent } from '@lib/instructor/class-roster';

interface Props {
  students: RosterStudent[];
  lessonsTotal: number;
  course: string;
  semester: string;
  usesSections: boolean;
  canManage: boolean;
}

const { students, lessonsTotal, course, semester, usesSections, canManage } =
  Astro.props;
const SECTION_OPTS = ['CML', 'CTL', 'CWL', 'CRL'];

function pct(v: number | null): string {
  return v == null ? '—' : `${Math.round(v * 100)}%`;
}

function lastSeen(iso: string | null): string {
  if (!iso) return 'never';
  const days = Math.floor((Date.now() - Date.parse(iso)) / 86_400_000);
  if (days <= 0) return 'today';
  if (days === 1) return '1d ago';
  return `${days}d ago`;
}
---

<div class="mt-4 overflow-x-auto rounded-lg border border-slate-200">
  <table class="w-full text-sm">
    <thead
      class="bg-slate-50 text-left text-xs uppercase tracking-wide text-ink-muted"
    >
      <tr>
        <th class="px-3 py-2 font-medium">Student</th>
        <th class="px-3 py-2 font-medium">Lessons</th>
        <th class="px-3 py-2 font-medium">Quizzes</th>
        <th class="px-3 py-2 font-medium">Avg</th>
        <th class="px-3 py-2 font-medium">Attend</th>
        <th class="px-3 py-2 font-medium">Last seen</th>
        <th class="px-3 py-2 font-medium">Flag</th>
        {canManage && <th class="px-3 py-2 font-medium">Manage</th>}
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      {
        students.map((s) => (
          <tr class={s.risk.atRisk ? 'bg-amber-50/60' : ''}>
            <td class="px-3 py-2">
              <div class="font-medium">
                {s.name ?? (
                  <span class="italic text-ink-muted">(no name set)</span>
                )}
              </div>
              <div class="text-xs text-ink-muted">{s.email ?? '—'}</div>
            </td>
            <td class="px-3 py-2 tabular-nums">
              {s.lessonsCompleted}/{lessonsTotal}
            </td>
            <td class="px-3 py-2 tabular-nums">{s.quizzesTaken}</td>
            <td class="px-3 py-2 tabular-nums">{pct(s.avgBestScore)}</td>
            <td class="px-3 py-2 tabular-nums">{s.attendanceCount}</td>
            <td class="px-3 py-2 whitespace-nowrap text-ink-muted">
              {lastSeen(s.lastActiveAt)}
            </td>
            <td class="px-3 py-2">
              {s.risk.atRisk ? (
                <span
                  class="inline-block cursor-help rounded bg-amber-100 px-2 py-0.5 text-xs font-semibold uppercase text-amber-800"
                  title={s.risk.reasons.join(' · ')}
                >
                  ⚠ at-risk
                </span>
              ) : (
                <span class="text-ink-muted">—</span>
              )}
            </td>
            {canManage && (
              <td class="px-3 py-2">
                <details>
                  <summary class="cursor-pointer text-xs text-accent">
                    Edit
                  </summary>
                  <form
                    method="POST"
                    action="/api/instructor/classes/update"
                    class="mt-2 flex flex-col gap-1"
                  >
                    <input type="hidden" name="course_slug" value={course} />
                    <input type="hidden" name="semester" value={semester} />
                    <input type="hidden" name="user_id" value={s.userId} />
                    <input
                      name="student_name"
                      placeholder="Display name"
                      value={s.name ?? ''}
                      class="rounded border border-slate-300 px-1 py-0.5 text-xs"
                    />
                    {usesSections && (
                      <select
                        name="section"
                        class="rounded border border-slate-300 px-1 py-0.5 text-xs"
                      >
                        <option value="" selected={!s.section}>
                          —
                        </option>
                        {SECTION_OPTS.map((o) => (
                          <option value={o} selected={s.section === o}>
                            {o}
                          </option>
                        ))}
                      </select>
                    )}
                    <button
                      type="submit"
                      class="rounded bg-accent px-2 py-0.5 text-xs text-white"
                    >
                      Save
                    </button>
                  </form>
                  <form
                    method="POST"
                    action="/api/instructor/classes/drop"
                    class="mt-2"
                    onsubmit="return confirm('Remove this student from the class?');"
                  >
                    <input type="hidden" name="course_slug" value={course} />
                    <input type="hidden" name="semester" value={semester} />
                    <input type="hidden" name="user_id" value={s.userId} />
                    <button
                      type="submit"
                      class="text-xs text-red-600 underline"
                    >
                      Remove
                    </button>
                  </form>
                </details>
              </td>
            )}
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
