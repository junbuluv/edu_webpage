---
import BaseLayout from '@layouts/BaseLayout.astro';
import Quiz from '@components/quiz/Quiz';
import { getCollection } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const quizzes = await getCollection('quizzes');
  return quizzes.map((q) => ({
    params: { slug: q.data.slug },
    props: { quiz: q.data },
  }));
}

interface Props {
  quiz: Awaited<ReturnType<typeof getCollection<'quizzes'>>>[number]['data'];
}
const { quiz } = Astro.props;
---

<BaseLayout title={quiz.title}>
  <div class="mx-auto max-w-3xl px-4 py-12">
    <p class="text-xs uppercase tracking-wide text-accent font-medium">
      Practice · {quiz.course}
    </p>
    <h1 class="text-2xl font-semibold tracking-tight mt-2">{quiz.title}</h1>

    <Quiz
      client:load
      slug={quiz.slug}
      title={quiz.title}
      questions={quiz.questions}
      passingScore={quiz.passingScore}
    />

    {quiz.furtherReading && (
      <section class="mt-10 rounded-lg border border-slate-200 bg-slate-50 p-5">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-ink-muted">
          Go one level deeper
        </h2>
        <a
          href={quiz.furtherReading.url}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 block text-lg font-medium text-accent underline"
        >
          {quiz.furtherReading.title}
        </a>
        <p class="mt-1 text-xs text-ink-muted">{quiz.furtherReading.source}</p>
        <p class="mt-3 text-sm">{quiz.furtherReading.why}</p>
      </section>
    )}

    {quiz.lessonSlug && (
      <p class="mt-8">
        <a href={`/lessons/${quiz.lessonSlug}`} class="text-sm text-accent underline">
          ← Back to the lesson
        </a>
      </p>
    )}
  </div>
</BaseLayout>
