---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const user = Astro.locals.user!;
const supabase = Astro.locals.supabase!;

const { slug } = Astro.params;
if (!slug) return new Response(null, { status: 404 });

const workshop = await getEntry('workshops', slug);
if (!workshop) return new Response(null, { status: 404 });

// Authorize: only an instructor of this course (any enrollments row
// where they're the instructor_id) can manage. Admins can view anything.
const role = Astro.locals.profile?.role ?? 'student';
const { data: rosterRow } = await supabase
  .from('enrollments')
  .select('user_id')
  .eq('instructor_id', user.id)
  .eq('course_slug', workshop.data.course)
  .maybeSingle();
const canManage = role === 'admin' || !!rosterRow;
if (!canManage) {
  return new Response(null, { status: 403 });
}

// CSV export branch
if (Astro.url.searchParams.get('format') === 'csv') {
  const { data: admins } = await supabase
    .from('workshop_administrations')
    .select('id, section, week_of, opens_at, closes_at')
    .eq('workshop_slug', slug)
    .order('week_of', { ascending: false });
  const adminIds = (admins ?? []).map((a) => a.id);
  let attendance: Array<{ administration_id: string; user_id: string; stamped_at: string }> = [];
  if (adminIds.length > 0) {
    const { data } = await supabase
      .from('workshop_attendance')
      .select('administration_id, user_id, stamped_at')
      .in('administration_id', adminIds);
    attendance = data ?? [];
  }
  const lines = ['administration_id,section,week_of,user_id,stamped_at'];
  const adminById = new Map((admins ?? []).map((a) => [a.id, a]));
  for (const r of attendance) {
    const a = adminById.get(r.administration_id);
    if (!a) continue;
    lines.push([r.administration_id, a.section, a.week_of, r.user_id, r.stamped_at].join(','));
  }
  return new Response(lines.join('\n'), {
    status: 200,
    headers: {
      'content-type': 'text/csv; charset=utf-8',
      'content-disposition': `attachment; filename="${slug}-attendance.csv"`,
    },
  });
}

// Load this workshop's administrations + roster.
const { data: admins } = await supabase
  .from('workshop_administrations')
  .select(
    'id, section, week_of, opens_at, closes_at, required_lat, required_lng, required_radius_meters, notes',
  )
  .eq('workshop_slug', slug)
  .order('week_of', { ascending: false })
  .order('section', { ascending: true });

const adminIds = (admins ?? []).map((a) => a.id);
let attendance: Array<{ administration_id: string; user_id: string; stamped_at: string }> = [];
if (adminIds.length > 0) {
  const { data } = await supabase
    .from('workshop_attendance')
    .select('administration_id, user_id, stamped_at')
    .in('administration_id', adminIds)
    .order('stamped_at', { ascending: true });
  attendance = data ?? [];
}

const stampsByAdmin = new Map<string, typeof attendance>();
for (const r of attendance) {
  const arr = stampsByAdmin.get(r.administration_id) ?? [];
  arr.push(r);
  stampsByAdmin.set(r.administration_id, arr);
}

function statusOf(opens: string, closes: string): 'open' | 'upcoming' | 'closed' {
  const now = Date.now();
  if (now < Date.parse(opens)) return 'upcoming';
  if (now > Date.parse(closes)) return 'closed';
  return 'open';
}

const SECTIONS = ['CML', 'CTL', 'CWL', 'CRL'] as const;

// Default values for the "Open a new section" form.
const todayLocal = new Date().toISOString().slice(0, 10);
const defaultOpensAt = new Date().toISOString().slice(0, 16);
const closeDefault = new Date(Date.now() + 2 * 60 * 60 * 1000).toISOString().slice(0, 16);
---

<BaseLayout title={`Manage: ${workshop.data.title}`}>
  <div class="mx-auto max-w-4xl px-4 py-12">
    <p class="text-xs uppercase tracking-wide text-accent font-medium">
      {workshop.data.course} · Instructor
    </p>
    <h1 class="mt-1 text-3xl font-semibold tracking-tight">{workshop.data.title}</h1>
    <p class="mt-3 text-ink-muted">{workshop.data.summary}</p>

    <section class="mt-10 rounded-lg border border-slate-200 p-5">
      <h2 class="text-lg font-semibold">Open a new section window</h2>
      <form method="POST" action="/api/instructor/workshops/open" class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-2">
        <input type="hidden" name="workshop_slug" value={workshop.data.slug} />
        <input type="hidden" name="course_slug" value={workshop.data.course} />

        <label class="text-sm">
          <span class="font-medium">Section</span>
          <select name="section" required class="mt-1 block w-full rounded border border-slate-300 px-2 py-1.5">
            {SECTIONS.map((s) => <option value={s}>{s}</option>)}
          </select>
        </label>

        <label class="text-sm">
          <span class="font-medium">Week of (Monday)</span>
          <input type="date" name="week_of" required value={todayLocal} class="mt-1 block w-full rounded border border-slate-300 px-2 py-1.5" />
        </label>

        <label class="text-sm">
          <span class="font-medium">Opens at (local)</span>
          <input type="datetime-local" name="opens_at" required value={defaultOpensAt} class="mt-1 block w-full rounded border border-slate-300 px-2 py-1.5" />
        </label>

        <label class="text-sm">
          <span class="font-medium">Closes at (local)</span>
          <input type="datetime-local" name="closes_at" required value={closeDefault} class="mt-1 block w-full rounded border border-slate-300 px-2 py-1.5" />
        </label>

        <label class="text-sm">
          <span class="font-medium">Geofence radius (m)</span>
          <input type="number" name="required_radius_meters" min="10" max="50000" value="200" class="mt-1 block w-full rounded border border-slate-300 px-2 py-1.5" />
          <span class="text-xs text-ink-muted">Defaults to 200 m around 55 Lexington Ave (40.7411, -73.9837). Leave alone unless meeting elsewhere.</span>
        </label>

        <label class="text-sm md:col-span-2">
          <span class="font-medium">Notes (optional)</span>
          <input type="text" name="notes" maxlength="200" class="mt-1 block w-full rounded border border-slate-300 px-2 py-1.5" />
        </label>

        <div class="md:col-span-2">
          <button type="submit" class="rounded bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
            Open section window
          </button>
        </div>
      </form>
    </section>

    <section class="mt-10">
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-semibold">Section windows & rosters</h2>
        {(admins?.length ?? 0) > 0 && (
          <a
            href={`/instructor/workshops/${slug}?format=csv`}
            class="rounded border border-slate-300 px-2 py-1 text-sm hover:border-accent"
          >
            Download CSV
          </a>
        )}
      </div>

      {(admins?.length ?? 0) === 0 && (
        <p class="mt-3 text-sm text-ink-muted">No section windows opened yet. Use the form above.</p>
      )}

      {(admins?.length ?? 0) > 0 && (
        <ul class="mt-4 space-y-4">
          {(admins ?? []).map((a) => {
            const status = statusOf(a.opens_at, a.closes_at);
            const stamps = stampsByAdmin.get(a.id) ?? [];
            return (
              <li class="rounded-lg border border-slate-200 p-4">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-sm font-medium">
                      Section {a.section} · week of {new Date(a.week_of).toLocaleDateString()}
                    </p>
                    <p class="mt-1 text-xs text-ink-muted">
                      Open {new Date(a.opens_at).toLocaleString()} —{' '}
                      {new Date(a.closes_at).toLocaleString()}
                    </p>
                    <p class="mt-0.5 text-xs text-ink-muted">
                      Geofence: within {a.required_radius_meters} m
                      {a.required_lat != null && (
                        <> of ({a.required_lat}, {a.required_lng})</>
                      )}
                    </p>
                    {a.notes && <p class="mt-1 text-xs text-ink-muted">{a.notes}</p>}
                  </div>
                  <div class="text-right">
                    <span
                      class={`inline-block whitespace-nowrap rounded px-2 py-0.5 text-xs font-semibold uppercase ${
                        status === 'open'
                          ? 'bg-emerald-100 text-emerald-800'
                          : status === 'upcoming'
                            ? 'bg-amber-100 text-amber-800'
                            : 'bg-slate-200 text-slate-700'
                      }`}
                    >
                      {status}
                    </span>
                    <p class="mt-1 text-xs text-ink-muted">{stamps.length} stamped</p>
                  </div>
                </div>

                {status !== 'closed' && (
                  <form method="POST" action="/api/instructor/workshops/close" class="mt-3">
                    <input type="hidden" name="administration_id" value={a.id} />
                    <button type="submit" class="rounded border border-rose-300 px-2 py-1 text-xs text-rose-800 hover:bg-rose-50">
                      Close window now
                    </button>
                  </form>
                )}

                {stamps.length > 0 && (
                  <details class="mt-3 text-sm">
                    <summary class="cursor-pointer text-ink-muted">Show roster ({stamps.length})</summary>
                    <ul class="mt-2 divide-y divide-slate-200 rounded border border-slate-200">
                      {stamps.map((s) => (
                        <li class="flex justify-between gap-3 px-3 py-2 text-xs">
                          <code class="truncate">{s.user_id}</code>
                          <span class="text-ink-muted">{new Date(s.stamped_at).toLocaleString()}</span>
                        </li>
                      ))}
                    </ul>
                  </details>
                )}
              </li>
            );
          })}
        </ul>
      )}
    </section>
  </div>
</BaseLayout>
