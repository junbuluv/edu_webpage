---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { isAdmin } from '@lib/roles';

const user = Astro.locals.user!;
const supabase = Astro.locals.supabase!;
const role = Astro.locals.profile?.role ?? 'student';

// Admins see all courses. Instructors/TAs see courses where they're
// listed as instructor_id on at least one enrollment row.
let instructorCourses = new Set<string>();
if (isAdmin(role)) {
  const allCourses = await getCollection('courses');
  for (const c of allCourses) instructorCourses.add(c.data.slug);
} else {
  const { data: rows } = await supabase
    .from('enrollments')
    .select('course_slug')
    .eq('instructor_id', user.id);
  for (const r of rows ?? []) instructorCourses.add(r.course_slug);
}

const allExams = await getCollection('exams');
const visible = allExams.filter((e) => instructorCourses.has(e.data.course));

const nowIso = new Date().toISOString();
const { data: openAdmins } = await supabase
  .from('exam_administrations')
  .select('exam_slug, opens_at, closes_at')
  .lte('opens_at', nowIso)
  .gt('closes_at', nowIso);
const openCountBySlug = new Map<string, number>();
for (const a of openAdmins ?? []) {
  openCountBySlug.set(a.exam_slug, (openCountBySlug.get(a.exam_slug) ?? 0) + 1);
}
---

<BaseLayout title="Instructor · Exams">
  <div class="mx-auto max-w-4xl px-4 py-12">
    <p class="text-xs uppercase tracking-wide text-accent font-medium">Instructor</p>
    <h1 class="mt-1 text-3xl font-semibold tracking-tight">Exams</h1>
    <p class="mt-3 text-ink-muted">
      Open and close proctored exam windows for your courses, view
      attempt rosters, and export results. One administration per exam
      per semester.
    </p>

    {instructorCourses.size === 0 && (
      <p class="mt-10 rounded border border-amber-300 bg-amber-50 p-5 text-sm text-amber-900">
        You're not listed as the instructor for any course yet. Ask an
        admin to add an enrollment row with your user id as the
        <code>instructor_id</code> for the courses you teach.
      </p>
    )}

    {visible.length > 0 && (
      <ul class="mt-8 space-y-3">
        {visible.map((e) => {
          const openCount = openCountBySlug.get(e.data.slug) ?? 0;
          return (
            <li class="rounded-lg border border-slate-200 p-5">
              <div class="flex items-start justify-between gap-3">
                <div class="flex-1">
                  <p class="text-xs uppercase tracking-wide text-accent font-medium">
                    {e.data.course}
                  </p>
                  <h2 class="mt-1 text-lg font-semibold">{e.data.title}</h2>
                  <p class="mt-1 text-sm text-ink-muted">{e.data.description}</p>
                  <p class="mt-2 text-xs text-ink-muted">
                    {e.data.questions.length} questions · {e.data.durationMinutes} min ·
                    pass {Math.round(e.data.passingScore * 100)}%
                  </p>
                </div>
                {openCount > 0 && (
                  <span class="inline-block whitespace-nowrap rounded bg-emerald-100 px-2 py-0.5 text-xs font-semibold uppercase text-emerald-800">
                    {openCount} open now
                  </span>
                )}
              </div>
              <div class="mt-3">
                <a
                  href={`/instructor/exams/${e.data.slug}`}
                  class="rounded border border-slate-300 px-3 py-1.5 text-sm font-medium hover:border-accent"
                >
                  Manage →
                </a>
              </div>
            </li>
          );
        })}
      </ul>
    )}

    {visible.length === 0 && instructorCourses.size > 0 && (
      <p class="mt-10 text-ink-muted">
        No exam content authored for your courses yet. Drop a JSON file
        under <code>src/content/exams/</code> following the schema in
        <code>src/content/config.ts</code>.
      </p>
    )}
  </div>
</BaseLayout>
