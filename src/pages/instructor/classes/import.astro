---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { isAdmin as isAdminRole, isStaff as isStaffRole } from '@lib/roles';
import { COURSE_SLUGS, isCourseSlug, type CourseSlug } from '@lib/courses';
import {
  previewImport,
  applyImport,
  RosterImportError,
  type ImportPreview,
} from '@lib/instructor/roster-import';
import { logDisclosureSafe } from '@lib/audit';

// Staff-gated by middleware (/instructor prefix), but guard explicitly
// rather than defaulting an absent profile to 'instructor'.
const user = Astro.locals.user!;
const rawRole = Astro.locals.profile?.role;
if (!isStaffRole(rawRole)) return new Response(null, { status: 403 });
const role = rawRole as 'instructor' | 'ta' | 'admin';
const isAdmin = isAdminRole(role);

let course: CourseSlug | null = null;
const qpCourse = Astro.url.searchParams.get('course');
if (qpCourse && isCourseSlug(qpCourse)) course = qpCourse;
let semester = Astro.url.searchParams.get('semester') ?? '';

let csvText = '';
let preview: ImportPreview | null = null;
let formError: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('action') ?? '');
  const fCourse = String(form.get('course') ?? '');
  semester = String(form.get('semester') ?? '').trim();
  csvText = String(form.get('csv') ?? '');
  course = isCourseSlug(fCourse) ? fCourse : null;

  if (!course || !semester) {
    formError = 'Choose a course and enter a semester.';
  } else if (!csvText.trim()) {
    formError = 'Paste roster CSV with a header row that includes an "email" column.';
  } else if (action === 'apply') {
    try {
      const result = await applyImport(user.id, isAdmin, course, semester, csvText);
      await logDisclosureSafe({
        actorId: user.id,
        actorRole: role,
        action: 'import_roster',
        targetResource: `${course}:${semester}`,
        metadata: {
          enrolled: result.enrolled,
          updated: result.updated,
          skipped: result.skipped,
          total: result.total,
        },
        request: Astro.request,
      });
      return Astro.redirect(
        `/instructor/classes/${course}?semester=${encodeURIComponent(semester)}` +
          `&imported=${result.enrolled}&updated=${result.updated}&skipped=${result.skipped}`,
      );
    } catch (err) {
      formError =
        err instanceof RosterImportError && err.code === 'forbidden'
          ? 'You can only import into a class you teach (or a brand-new one). This course and semester is managed by another instructor.'
          : 'Import failed — the auth or database service may be temporarily unavailable. Try again.';
    }
  } else {
    try {
      preview = await previewImport(user.id, isAdmin, course, semester, csvText);
    } catch {
      formError = 'Could not build the preview — the auth or database service may be temporarily unavailable. Try again.';
    }
  }
}

const courseMeta = new Map(
  (await getCollection('courses')).map((c) => [c.data.slug, c.data]),
);
---

<BaseLayout title="Import roster">
  <div class="mx-auto max-w-4xl px-4 py-12">
    <p class="text-xs uppercase tracking-wide text-accent font-medium">Instructor · Roster import</p>
    <h1 class="mt-1 text-3xl font-semibold tracking-tight">Import a class roster</h1>
    <p class="mt-3 text-ink-muted">
      Paste a CSV with a header row that includes an <code>email</code> column
      (optionally <code>name</code> and <code>section</code>). Students who
      already have an account are enrolled; those who haven't signed up yet are
      listed so you can re-import later. Re-running is safe.
    </p>
    <p class="mt-2 text-sm">
      <a href="/instructor/classes" class="text-accent underline">← All classes</a>
    </p>

    {formError && (
      <div class="mt-6 rounded-lg border border-amber-300 bg-amber-50 p-4 text-sm text-amber-900">{formError}</div>
    )}

    <form method="POST" class="mt-8 space-y-4">
      <input type="hidden" name="action" value="preview" />
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <label class="text-sm">
          <span class="font-medium">Course</span>
          <select name="course" required class="mt-1 block w-full rounded border border-slate-300 px-2 py-1.5">
            {COURSE_SLUGS.map((slug) => (
              <option value={slug} selected={course === slug}>
                {courseMeta.get(slug)?.code ?? slug}
              </option>
            ))}
          </select>
        </label>
        <label class="text-sm">
          <span class="font-medium">Semester</span>
          <input
            type="text"
            name="semester"
            required
            value={semester}
            placeholder="e.g. Spring 2026"
            class="mt-1 block w-full rounded border border-slate-300 px-2 py-1.5"
          />
        </label>
      </div>
      <label class="block text-sm">
        <span class="font-medium">Roster CSV</span>
        <textarea
          name="csv"
          rows="10"
          required
          placeholder="email,name,section&#10;jane@x.edu,Jane Doe,CML"
          class="mt-1 block w-full rounded border border-slate-300 px-2 py-1.5 font-mono text-xs"
        >{csvText}</textarea>
      </label>
      <button type="submit" class="rounded bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
        Preview import
      </button>
    </form>

    {preview && course && (
      <section class="mt-10">
        <h2 class="text-lg font-semibold">Preview</h2>
        <p class="mt-1 text-sm text-ink-muted">
          {preview.total} row{preview.total === 1 ? '' : 's'} parsed ·
          <strong> {preview.toEnroll.length}</strong> to enroll ·
          <strong> {preview.toUpdate.length}</strong> already enrolled (will update) ·
          <strong> {preview.unmatched.length}</strong> unmatched (no account yet)
        </p>

        {preview.parseErrors.length > 0 && (
          <div class="mt-3 rounded border border-amber-300 bg-amber-50 p-3 text-xs text-amber-900">
            <p class="font-medium">{preview.parseErrors.length} row(s) skipped:</p>
            <ul class="mt-1 list-disc pl-5">
              {preview.parseErrors.slice(0, 20).map((e) => <li>{e}</li>)}
            </ul>
          </div>
        )}

        {preview.unmatched.length > 0 && (
          <details class="mt-4 text-sm">
            <summary class="cursor-pointer text-ink-muted">
              {preview.unmatched.length} unmatched (no account yet — re-import after they sign up)
            </summary>
            <ul class="mt-2 rounded border border-slate-200 p-3 text-xs text-ink-muted">
              {preview.unmatched.map((r) => <li>{r.email}</li>)}
            </ul>
          </details>
        )}

        {preview.ownedByOther ? (
          <p class="mt-5 rounded border border-amber-300 bg-amber-50 p-3 text-sm text-amber-900">
            This course and semester is managed by another instructor, so you
            can't import into it. Ask an admin if you should have access.
          </p>
        ) : (preview.toEnroll.length > 0 || preview.toUpdate.length > 0) ? (
          <form method="POST" class="mt-5">
            <input type="hidden" name="action" value="apply" />
            <input type="hidden" name="course" value={course} />
            <input type="hidden" name="semester" value={semester} />
            <textarea name="csv" class="hidden">{csvText}</textarea>
            <button type="submit" class="rounded bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700">
              Confirm import ({preview.toEnroll.length + preview.toUpdate.length} students)
            </button>
          </form>
        ) : (
          <p class="mt-5 text-sm text-ink-muted">Nothing to import — no rows matched an existing account.</p>
        )}
      </section>
    )}
  </div>
</BaseLayout>
