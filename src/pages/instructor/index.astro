---
import BaseLayout from '@layouts/BaseLayout.astro';

const user = Astro.locals.user!;
const profile = Astro.locals.profile!;
const supabase = Astro.locals.supabase!;

const { data: rosters } = await supabase
  .from('enrollments')
  .select('course_slug, semester, user_id')
  .order('semester', { ascending: false });
---

<BaseLayout title="Instructor">
  <div class="mx-auto max-w-3xl px-4 py-12">
    <p class="text-xs uppercase tracking-wide text-accent font-medium">Instructor</p>
    <h1 class="mt-1 text-3xl font-semibold tracking-tight">Your classes</h1>
    <p class="mt-3 text-ink-muted">
      Signed in as {profile.display_name ?? user.email}.
    </p>

    {rosters && rosters.length > 0 ? (
      <ul class="mt-8 divide-y divide-slate-200 rounded border border-slate-200">
        {rosters.map((r) => (
          <li class="px-4 py-3">
            <div class="font-medium">{r.course_slug}</div>
            <div class="text-sm text-ink-muted">{r.semester} · student id {r.user_id}</div>
          </li>
        ))}
      </ul>
    ) : (
      <p class="mt-8 text-ink-muted">
        No rosters yet. An admin can seed them via SQL or you can upload one
        once the roster-upload UI ships.
      </p>
    )}
  </div>
</BaseLayout>
