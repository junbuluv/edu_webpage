---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';
import InstructorProfile from '@components/instructor/InstructorProfile.astro';

const { slug } = Astro.params;
if (!slug) return new Response(null, { status: 404 });
const instructor = await getEntry('instructors', slug);
if (!instructor || !instructor.data.courses.includes('fin-3610')) {
  return new Response(null, { status: 404 });
}
---

<BaseLayout title={`${instructor.data.fullName} — Instructor profile`}>
  <InstructorProfile
    instructor={instructor}
    courseCode="FIN 3610"
    backHref="/fin-3610/instructors"
  />
</BaseLayout>
