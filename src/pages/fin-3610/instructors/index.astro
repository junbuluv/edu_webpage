---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import InstructorCard from '@components/instructor/InstructorCard.astro';

const instructors = (
  await getCollection('instructors', (i) => i.data.courses.includes('fin-3610'))
).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="FIN 3610 — Instructors">
  <div class="mx-auto max-w-4xl px-4 py-12">
    <p class="text-xs uppercase tracking-wide text-accent font-medium">
      FIN 3610
    </p>
    <h1 class="mt-1 text-3xl font-semibold tracking-tight">Instructors</h1>
    <p class="mt-3 text-ink-muted">
      FIN 3610 — Corporate Finance is taught by faculty in the Bert W. Wasserman
      Department of Economics and Finance at Baruch College's Zicklin School of
      Business.
    </p>

    {
      instructors.length === 0 && (
        <p class="mt-10 text-ink-muted">
          No instructor profiles published yet.
        </p>
      )
    }

    {
      instructors.length > 0 && (
        <ul class="mt-10 grid gap-4 md:grid-cols-2">
          {instructors.map((i) => (
            <li>
              <InstructorCard
                instructor={i}
                href={`/fin-3610/instructors/${i.slug}`}
              />
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>
