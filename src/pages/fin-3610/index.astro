---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { isAdmin } from '@lib/roles';

const user = Astro.locals.user;
const supabase = Astro.locals.supabase;

const lessons = (await getCollection('lessons', (l) => !l.data.draft && l.data.course === 'fin-3610'))
  .sort((a, b) => a.data.order - b.data.order);

const byUnit = new Map<string, typeof lessons>();
for (const l of lessons) {
  const arr = byUnit.get(l.data.unit) ?? [];
  arr.push(l);
  byUnit.set(l.data.unit, arr);
}

// Enrollment-gated quiz teaser (admins also see it as view-as).
const viewerIsAdmin = isAdmin(Astro.locals.profile?.role);
let enrolled = false;
let openQuizCount = 0;
let totalQuizCount = 0;
if (user && supabase) {
  const { data: enrollment } = await supabase
    .from('enrollments')
    .select('user_id')
    .eq('user_id', user.id)
    .eq('course_slug', 'fin-3610')
    .maybeSingle();
  enrolled = !!enrollment;
  if (enrolled || viewerIsAdmin) {
    const quizContent = await getCollection('exams', (e) => e.data.course === 'fin-3610');
    totalQuizCount = quizContent.length;
    const nowIso = new Date().toISOString();
    const { data: openAdmins } = await supabase
      .from('exam_administrations')
      .select('id')
      .eq('course_slug', 'fin-3610')
      .lte('opens_at', nowIso)
      .gt('closes_at', nowIso);
    openQuizCount = (openAdmins ?? []).length;
  }
}
const showQuizTeaser = enrolled || viewerIsAdmin;
---

<BaseLayout title="FIN 3610 — Corporate Finance">
  <div class="mx-auto max-w-4xl px-4 py-12">
    <p class="text-xs uppercase tracking-wide text-accent font-medium">Course</p>
    <h1 class="mt-1 text-3xl font-semibold tracking-tight">
      FIN 3610 — Corporate Finance
    </h1>
    <p class="mt-3 text-ink-muted max-w-2xl">
      Upper-division corporate finance, aligned to Berk &amp; DeMarzo 6e.
      Time value of money, valuation, risk and return, capital structure,
      payout, options, and special topics. Includes interactive TVM, bond
      pricing, CAPM, WACC, and project-cashflow visualizations.
    </p>

    {showQuizTeaser && totalQuizCount > 0 && (
      <section class="mt-10 rounded-lg border border-slate-200 bg-slate-50 p-5">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <h2 class="text-xl font-semibold">Quizzes</h2>
            <p class="mt-1 text-sm text-ink-muted">
              {totalQuizCount} proctored quiz{totalQuizCount === 1 ? '' : 'zes'} for
              this course. Time-windowed and location-gated.
              {openQuizCount > 0 && (
                <span class="ml-1 font-medium text-emerald-700">
                  {openQuizCount} open right now.
                </span>
              )}
              {viewerIsAdmin && !enrolled && (
                <span class="ml-1 italic text-sky-700">(admin view)</span>
              )}
            </p>
          </div>
          <a
            href="/fin-3610/quizzes"
            class="rounded bg-accent px-3 py-1.5 text-sm font-medium text-white hover:bg-blue-700"
          >
            See all quizzes →
          </a>
        </div>
      </section>
    )}

    {[...byUnit.entries()].map(([unit, items]) => (
      <section class="mt-10">
        <h2 class="text-xl font-semibold">{unit}</h2>
        <ol class="mt-4 space-y-2">
          {items.map((l) => (
            <li>
              <a href={`/lessons/${l.slug}`}
                 class="flex items-baseline justify-between rounded border border-slate-200 px-4 py-3 hover:border-accent">
                <span class="font-medium">{l.data.title}</span>
                <span class="text-sm text-ink-muted">⏱ {l.data.estimatedMinutes} min</span>
              </a>
            </li>
          ))}
        </ol>
      </section>
    ))}

    {lessons.length === 0 && (
      <p class="mt-10 text-ink-muted">No lessons published yet.</p>
    )}
  </div>
</BaseLayout>
