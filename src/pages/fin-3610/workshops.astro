---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { isAdmin } from '@lib/roles';

// Public list page (same pattern as eco-1002): anyone can browse the
// titles + summaries + lesson links. Open-window status only renders
// for enrolled students or admins.

const user = Astro.locals.user;
const supabase = Astro.locals.supabase;
const role = Astro.locals.profile?.role ?? 'student';
const viewerIsAdmin = isAdmin(role);
const isGuest = !user;

let enrolled = false;
if (user && supabase) {
  const { data } = await supabase
    .from('enrollments')
    .select('user_id')
    .eq('user_id', user.id)
    .eq('course_slug', 'fin-3610')
    .maybeSingle();
  enrolled = !!data;
}
const canSeeOpenWindows = enrolled || viewerIsAdmin;

const workshops = (
  await getCollection('workshops', (w) => w.data.course === 'fin-3610')
).sort((a, b) => a.data.slug.localeCompare(b.data.slug));

const nowIso = new Date().toISOString();
type AdminRow = {
  id: string;
  workshop_slug: string;
  opens_at: string;
  closes_at: string;
  week_of: string;
};
let admins: AdminRow[] = [];
if (canSeeOpenWindows && supabase) {
  const { data } = await supabase
    .from('workshop_administrations')
    .select('id, workshop_slug, opens_at, closes_at, week_of')
    .eq('course_slug', 'fin-3610')
    .gt('closes_at', nowIso)
    .order('opens_at', { ascending: true });
  admins = (data ?? []) as AdminRow[];
}
const adminsBySlug = new Map<string, AdminRow[]>();
for (const a of admins) {
  const arr = adminsBySlug.get(a.workshop_slug) ?? [];
  arr.push(a);
  adminsBySlug.set(a.workshop_slug, arr);
}

function statusOf(
  opens: string,
  closes: string,
): 'open' | 'upcoming' | 'closed' {
  const now = Date.now();
  if (now < Date.parse(opens)) return 'upcoming';
  if (now > Date.parse(closes)) return 'closed';
  return 'open';
}
---

<BaseLayout title="FIN 3610 — Workshops">
  <div class="mx-auto max-w-3xl px-4 py-12">
    <p class="text-xs uppercase tracking-wide text-accent font-medium">
      FIN 3610
    </p>
    <h1 class="mt-1 text-3xl font-semibold tracking-tight">Workshops</h1>
    <p class="mt-3 text-ink-muted">
      Weekly small-group discussion sessions, one per FIN 3610 unit. Stamp in
      during class to record participation.
    </p>

    {
      isGuest && (
        <div class="mt-8 rounded border border-sky-300 bg-sky-50 p-4 text-sm text-sky-900">
          <p>
            <a
              class="text-accent underline"
              href={`/auth/signin?next=${encodeURIComponent('/fin-3610/workshops')}`}
            >
              Sign in
            </a>{' '}
            to see open session windows and stamp in.
          </p>
        </div>
      )
    }

    {
      user && !enrolled && !viewerIsAdmin && (
        <div class="mt-8 rounded border border-amber-300 bg-amber-50 p-5 text-sm text-amber-900">
          <p class="font-medium">You're not enrolled in FIN 3610.</p>
          <p class="mt-2">
            You can browse the workshop list below, but open session windows and
            stamp-in are only available to enrolled students. Ask your
            instructor to add you to the roster.
          </p>
        </div>
      )
    }

    {
      viewerIsAdmin && !enrolled && (
        <div class="mt-8 rounded border border-sky-300 bg-sky-50 p-3 text-xs text-sky-900">
          <strong>Admin view.</strong> You're seeing this page without being
          enrolled in FIN 3610.
        </div>
      )
    }

    {
      workshops.length === 0 && (
        <p class="mt-8 text-ink-muted">No workshops authored yet.</p>
      )
    }

    {
      workshops.length > 0 && (
        <ul class="mt-8 space-y-4">
          {workshops.map((w) => {
            const wAdmins = adminsBySlug.get(w.data.slug) ?? [];
            return (
              <li class="rounded-lg border border-slate-200 p-5">
                <h2 class="text-lg font-semibold">{w.data.title}</h2>
                <p class="mt-1 text-sm text-ink-muted">{w.data.summary}</p>
                <p class="mt-2 text-xs text-ink-muted">
                  Lesson:{' '}
                  <a
                    class="text-accent underline"
                    href={`/lessons/${w.data.lessonSlug}`}
                  >
                    {w.data.lessonSlug}
                  </a>{' '}
                  · {w.data.questions.length} discussion questions
                </p>

                {canSeeOpenWindows &&
                  (wAdmins.length === 0 ? (
                    <p class="mt-3 rounded bg-slate-50 px-3 py-2 text-xs text-ink-muted">
                      No workshop windows scheduled. Your instructor will open
                      them at meeting times.
                    </p>
                  ) : (
                    <ul class="mt-3 space-y-1">
                      {wAdmins.map((a) => {
                        const status = statusOf(a.opens_at, a.closes_at);
                        return (
                          <li class="flex items-center justify-between gap-3 rounded bg-slate-50 px-3 py-1.5 text-xs">
                            <span>
                              Week of {new Date(a.week_of).toLocaleDateString()}
                            </span>
                            <span
                              class={`rounded px-1.5 py-0.5 font-semibold uppercase ${
                                status === 'open'
                                  ? 'bg-emerald-100 text-emerald-800'
                                  : status === 'upcoming'
                                    ? 'bg-amber-100 text-amber-800'
                                    : 'bg-slate-200 text-slate-700'
                              }`}
                            >
                              {status}
                            </span>
                          </li>
                        );
                      })}
                    </ul>
                  ))}

                <div class="mt-3">
                  <a
                    href={`/workshops/${w.data.slug}`}
                    class="rounded bg-accent px-3 py-1.5 text-sm font-medium text-white hover:bg-blue-700"
                  >
                    Go to workshop →
                  </a>
                </div>
              </li>
            );
          })}
        </ul>
      )
    }
  </div>
</BaseLayout>
