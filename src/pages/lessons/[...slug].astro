---
import { getEntry } from 'astro:content';
import LessonLayout from '@layouts/LessonLayout.astro';

// SSR (not prerendered) so Astro.locals.user is populated by middleware
// and the header renders the signed-in state. Tradeoff: each lesson
// request hits Supabase via middleware. Acceptable for class-sized
// traffic; revisit with a server island if scale demands.

const { slug } = Astro.params;
if (!slug) {
  return new Response(null, { status: 404 });
}
const lesson = await getEntry('lessons', slug);
if (!lesson || lesson.data.draft) {
  return new Response(null, { status: 404 });
}
const { Content } = await lesson.render();
---

<LessonLayout lesson={lesson}>
  <Content />
</LessonLayout>
