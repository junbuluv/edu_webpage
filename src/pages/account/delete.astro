---
import BaseLayout from '@layouts/BaseLayout.astro';

const user = Astro.locals.user!;
const error = Astro.url.searchParams.get('error');
---

<BaseLayout title="Delete account">
  <div class="mx-auto max-w-xl py-16 px-4">
    <h1 class="text-2xl font-semibold">Delete your account</h1>
    <p class="mt-3 text-ink-muted">
      This permanently removes your profile, lesson progress, quiz attempts, and
      authentication record for <strong>{user.email}</strong>. It cannot be
      undone.
    </p>

    {
      error && (
        <div class="mt-6 rounded border border-red-300 bg-red-50 p-3 text-sm text-red-800">
          {decodeURIComponent(error)}
        </div>
      )
    }

    <form method="POST" action="/api/account/delete" class="mt-8 space-y-4">
      <label class="block">
        <span class="text-sm font-medium">
          Type <code class="rounded bg-slate-100 px-1.5">delete my account</code
          > to confirm:
        </span>
        <input
          name="confirm"
          type="text"
          required
          autocomplete="off"
          class="mt-1 w-full rounded border border-slate-300 px-3 py-2"
        />
      </label>
      <button
        type="submit"
        class="w-full rounded bg-red-600 px-4 py-2 font-medium text-white hover:bg-red-700"
      >
        Permanently delete my account
      </button>
    </form>

    <p class="mt-6 text-sm text-ink-muted">
      <a class="text-accent underline" href="/dashboard"
        >Cancel and return to dashboard</a
      >
    </p>
  </div>
</BaseLayout>
