---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import InstructorCard from '@components/instructor/InstructorCard.astro';

const instructors = (
  await getCollection('instructors', (i) => i.data.courses.includes('eco-1002'))
).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="ECO 1002 — Instructors">
  <div class="mx-auto max-w-4xl px-4 py-12">
    <p class="text-xs uppercase tracking-wide text-accent font-medium">
      ECO 1002
    </p>
    <h1 class="mt-1 text-3xl font-semibold tracking-tight">Instructors</h1>
    <p class="mt-3 text-ink-muted">
      ECO 1002 is taught by faculty across the Bert W. Wasserman Department of
      Economics and Finance at Baruch College's Zicklin School of Business.
    </p>

    <ul class="mt-10 grid gap-4 md:grid-cols-2">
      {
        instructors.map((i) => (
          <li>
            <InstructorCard
              instructor={i}
              href={`/eco-1002/instructors/${i.slug}`}
            />
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
