---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getAdminClient } from '@lib/supabase/admin';

const user = Astro.locals.user!;
const profile = Astro.locals.profile!;

// Recent management activity from the audit log (read-only). Admin-gated by
// middleware; read via service-role since audit_log has no read RLS policy.
const admin = getAdminClient();
const { data: events } = await admin
  .from('audit_log')
  .select('id, ts, actor_id, actor_role, action, target_resource')
  .order('ts', { ascending: false })
  .limit(50);

const actorIds = [
  ...new Set(
    (events ?? []).map((e) => e.actor_id).filter((x): x is string => !!x),
  ),
];
let actorNameById = new Map<string, string | null>();
if (actorIds.length > 0) {
  const { data: profs } = await admin
    .from('profiles')
    .select('id, display_name')
    .in('id', actorIds);
  actorNameById = new Map((profs ?? []).map((p) => [p.id, p.display_name]));
}

// Banner for the role-assignment form (?ok= / ?error= per convention #16).
const ROLE_OK: Record<string, string> = {
  role_set: 'Role updated.',
  role_unchanged: 'That user already has that role; nothing changed.',
};
const ROLE_ERR: Record<string, string> = {
  unauthenticated: 'Please sign in.',
  forbidden: 'You do not have permission to assign roles.',
  invalid_input: 'Enter an email and pick a role.',
  invalid_role: 'That role cannot be assigned here (admin stays SQL-only).',
  no_account: 'No account found for that email. The person must sign up first.',
  cannot_modify_admin:
    'That user is an admin; admin roles are managed via SQL, not here.',
  lookup_failed: 'Could not look up that account right now. Please try again.',
  update_failed: 'Could not update the role. Please try again.',
  role_set_unaudited:
    'Role updated, but it could not be written to the audit log. Please report this to an admin.',
};
const okParam = Astro.url.searchParams.get('ok');
const errParam = Astro.url.searchParams.get('error');
const roleOkText = okParam ? (ROLE_OK[okParam] ?? null) : null;
const roleErrText = errParam ? (ROLE_ERR[errParam] ?? null) : null;
---

<BaseLayout title="Admin">
  <div class="mx-auto max-w-3xl px-4 py-12">
    <p class="text-xs uppercase tracking-wide text-accent font-medium">Admin</p>
    <h1 class="mt-1 text-3xl font-semibold tracking-tight">
      Site administration
    </h1>
    <p class="mt-3 text-ink-muted">
      Signed in as {profile.display_name ?? user.email}. Role: {profile.role}.
    </p>

    <section class="mt-10 rounded-lg border border-slate-200 p-5">
      <h2 class="text-lg font-semibold">User roles</h2>
      <p class="mt-1 text-sm text-ink-muted">
        Set a user's role by email. They must have signed up first. Granting or
        revoking <strong>admin</strong> stays SQL-only by design, so this only offers
        student, instructor, and ta.
      </p>

      {
        roleOkText && (
          <p class="mt-4 rounded border border-green-300 bg-green-50 p-3 text-sm text-green-800">
            {roleOkText}
          </p>
        )
      }
      {
        roleErrText && (
          <p class="mt-4 rounded border border-amber-300 bg-amber-50 p-3 text-sm text-amber-900">
            {roleErrText}
          </p>
        )
      }

      <form
        method="POST"
        action="/api/admin/assign-role"
        class="mt-4 flex flex-wrap items-end gap-3 text-sm"
      >
        <label class="block flex-1">
          <span class="text-ink-muted">Email</span>
          <input
            name="email"
            type="email"
            required
            placeholder="person@baruch.cuny.edu"
            class="mt-1 w-full rounded border border-slate-300 px-2 py-1"
          />
        </label>
        <label class="block">
          <span class="text-ink-muted">Role</span>
          <select
            name="role"
            required
            class="mt-1 rounded border border-slate-300 px-2 py-1"
          >
            <option value="student">student</option>
            <option value="instructor">instructor</option>
            <option value="ta">ta</option>
          </select>
        </label>
        <button
          type="submit"
          class="rounded bg-accent px-3 py-1.5 font-medium text-white hover:bg-blue-700"
        >
          Set role
        </button>
      </form>

      <p class="mt-3 text-xs text-ink-muted">
        Assigning instructor or ta lets the user teach; assign them to a
        specific course from the roster (Manage, then classes). Other admin
        actions go through SQL; see <a
          class="text-accent underline"
          href="https://github.com/junbuluv/edu_webpage/blob/main/CONTRIBUTING.md"
          >CONTRIBUTING.md</a
        >.
      </p>
    </section>

    <section class="mt-12">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-ink-muted">
        Recent activity
      </h2>
      <p class="mt-1 text-xs text-ink-muted">
        Last 50 audited events (roster imports, student-data exports, and other
        disclosures). IP / user-agent are HMAC'd, not shown.
      </p>

      {
        !events || events.length === 0 ? (
          <p class="mt-4 text-sm text-ink-muted">No audited events yet.</p>
        ) : (
          <div class="mt-4 overflow-x-auto rounded-lg border border-slate-200">
            <table class="w-full text-sm">
              <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-ink-muted">
                <tr>
                  <th class="px-3 py-2 font-medium">When</th>
                  <th class="px-3 py-2 font-medium">Actor</th>
                  <th class="px-3 py-2 font-medium">Action</th>
                  <th class="px-3 py-2 font-medium">Target</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {events.map((e) => (
                  <tr>
                    <td class="px-3 py-2 whitespace-nowrap text-ink-muted">
                      {new Date(e.ts).toLocaleString()}
                    </td>
                    <td class="px-3 py-2">
                      {e.actor_id
                        ? (actorNameById.get(e.actor_id) ?? '—')
                        : '—'}
                      {e.actor_role && (
                        <span class="ml-1 text-xs text-ink-muted">
                          ({e.actor_role})
                        </span>
                      )}
                    </td>
                    <td class="px-3 py-2">
                      <code class="text-xs">{e.action}</code>
                    </td>
                    <td class="px-3 py-2 text-xs text-ink-muted">
                      {e.target_resource ?? '—'}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )
      }
    </section>
  </div>
</BaseLayout>
