---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';
import StampInButton from '@components/workshop/StampInButton';
import { isAdmin } from '@lib/roles';

const user = Astro.locals.user!;
const supabase = Astro.locals.supabase!;

const { slug } = Astro.params;
if (!slug) {
  return new Response(null, { status: 404 });
}
const workshop = await getEntry('workshops', slug);
if (!workshop) {
  return new Response(null, { status: 404 });
}

// Enrollment gate: students enrolled in the course OR admins see the
// schedule. Admin "view-as" sees the page but won't be able to stamp
// unless they're also enrolled (the stamp API still requires enrollment
// or being the course's instructor).
const viewerIsAdmin = isAdmin(Astro.locals.profile?.role);
const { data: enrollment } = await supabase
  .from('enrollments')
  .select('user_id')
  .eq('user_id', user.id)
  .eq('course_slug', workshop.data.course)
  .maybeSingle();
const enrolled = !!enrollment;
const canView = enrolled || viewerIsAdmin;

// Pull this workshop's administrations across all sections, sorted by
// section then opens_at. Only show those whose closes_at is still in
// the future (don't leak past windows).
const nowIso = new Date().toISOString();
const { data: admins } = canView
  ? await supabase
      .from('workshop_administrations')
      .select(
        'id, section, week_of, opens_at, closes_at, required_lat, required_lng, required_radius_meters, notes',
      )
      .eq('workshop_slug', workshop.data.slug)
      .gt('closes_at', nowIso)
      .order('opens_at', { ascending: true })
  : { data: [] };

const myAttempts = canView
  ? await supabase
      .from('workshop_attendance')
      .select('administration_id, stamped_at')
      .eq('user_id', user.id)
  : { data: [] };
const stampedSet = new Set((myAttempts.data ?? []).map((a) => a.administration_id));

function statusOf(opens: string, closes: string): 'open' | 'upcoming' | 'closed' {
  const now = Date.now();
  if (now < Date.parse(opens)) return 'upcoming';
  if (now > Date.parse(closes)) return 'closed';
  return 'open';
}
---

<BaseLayout title={workshop.data.title}>
  <article class="mx-auto max-w-3xl px-4 py-12">
    <p class="text-xs uppercase tracking-wide text-accent font-medium">
      {workshop.data.course} · Workshop
    </p>
    <h1 class="mt-1 text-3xl font-semibold tracking-tight">{workshop.data.title}</h1>
    <p class="mt-3 text-ink-muted">{workshop.data.summary}</p>

    {!canView && (
      <div class="mt-8 rounded border border-amber-300 bg-amber-50 p-5 text-sm text-amber-900">
        <p class="font-medium">You're not enrolled in this course.</p>
        <p class="mt-2">
          Workshop attendance is only available to enrolled students. Ask
          your instructor to add you to the roster.
        </p>
      </div>
    )}

    {canView && !enrolled && viewerIsAdmin && (
      <div class="mt-6 rounded border border-sky-300 bg-sky-50 p-3 text-xs text-sky-900">
        <strong>Admin view.</strong> You're viewing this page without being enrolled. Stamping is not available without enrollment.
      </div>
    )}

    {canView && (admins ?? []).length === 0 && (
      <div class="mt-8 rounded border border-slate-200 bg-slate-50 p-5 text-sm text-ink-muted">
        <p>
          <strong>No workshop sessions are scheduled right now.</strong>{' '}
          Your instructor will open Monday (CML), Tuesday (CTL), Wednesday
          (CWL), and Thursday (CRL) sections each week. Come back during
          class time.
        </p>
      </div>
    )}

    {canView && (admins?.length ?? 0) > 0 && (
      <section class="mt-10">
        <h2 class="text-xl font-semibold">This week's sections</h2>
        <p class="mt-1 text-sm text-ink-muted">
          Stamp in for <em>your</em> section once you're physically in the
          room. One stamp per device per session.
        </p>
        <ul class="mt-4 space-y-3">
          {(admins ?? []).map((a) => {
            const status = statusOf(a.opens_at, a.closes_at);
            const alreadyStamped = stampedSet.has(a.id);
            return (
              <li class="rounded-lg border border-slate-200 p-4">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-sm font-medium">
                      Section {a.section} · week of {new Date(a.week_of).toLocaleDateString()}
                    </p>
                    <p class="mt-1 text-xs text-ink-muted">
                      Open {new Date(a.opens_at).toLocaleString()} — closes{' '}
                      {new Date(a.closes_at).toLocaleString()}
                    </p>
                    {a.notes && <p class="mt-1 text-xs text-ink-muted">{a.notes}</p>}
                  </div>
                  <span
                    class={`inline-block whitespace-nowrap rounded px-2 py-0.5 text-xs font-semibold uppercase ${
                      status === 'open'
                        ? 'bg-emerald-100 text-emerald-800'
                        : status === 'upcoming'
                          ? 'bg-amber-100 text-amber-800'
                          : 'bg-slate-200 text-slate-700'
                    }`}
                  >
                    {status}
                  </span>
                </div>
                <div class="mt-3">
                  {alreadyStamped ? (
                    <p class="rounded border border-emerald-300 bg-emerald-50 p-2 text-sm text-emerald-900">
                      ✓ You're already stamped in for this section. Discussion
                      questions appear once your instructor reveals them in
                      class.
                    </p>
                  ) : status === 'open' ? (
                    <StampInButton
                      client:load
                      administrationId={a.id}
                      section={a.section}
                      requiredLat={a.required_lat}
                      requiredLng={a.required_lng}
                      requiredRadiusMeters={a.required_radius_meters}
                    />
                  ) : status === 'upcoming' ? (
                    <p class="text-sm text-ink-muted">Stamping opens at the start time above.</p>
                  ) : (
                    <p class="text-sm text-ink-muted">Window closed.</p>
                  )}
                </div>
              </li>
            );
          })}
        </ul>
      </section>
    )}

    <p class="mt-12 text-xs text-ink-muted">
      <strong>How attendance is verified.</strong> Stamping records your
      location (within the geofence radius set for this session) and a
      device cookie tied to this browser. The same device can only be
      used to stamp one student per session. This is a soft barrier
      designed to prevent the most common attempts at proxy attendance;
      a determined student can defeat it. Your instructor may still take
      an in-person headcount.
    </p>
  </article>
</BaseLayout>
