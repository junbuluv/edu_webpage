---
import BaseLayout from '@layouts/BaseLayout.astro';
import TypingVerb from '@components/hero/TypingVerb';
import { getCollection } from 'astro:content';

const allLessons = (await getCollection('lessons', (l) => !l.data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const courses = [
  {
    code: 'eco-1002',
    title: 'ECO 1002 — Introduction to Macroeconomics',
    blurb: 'First-year intro macro: GDP, inflation, the Fed, AD-AS, growth.',
    href: '/eco-1002',
  },
  {
    code: 'fin-3610',
    title: 'FIN 3610 — Corporate Finance',
    blurb: 'Upper-division: TVM, valuation, risk/return, capital structure, options.',
    href: '/fin-3610',
  },
];

const stats = courses.map((c) => ({
  ...c,
  count: allLessons.filter((l) => l.data.course === c.code).length,
}));
---

<BaseLayout title="Baruch Econ & Finance Studio">
  <section class="border-b border-slate-200 bg-gradient-to-b from-white to-slate-50">
    <div class="mx-auto max-w-4xl px-4 py-20 text-center">
      <h1 class="text-4xl font-semibold tracking-tight md:text-5xl">
        Economics &amp; Finance you can{' '}
        <TypingVerb
          client:load
          verbs={[
            'play with',
            'explore',
            'tinker with',
            'simulate',
            'visualize',
          ]}
        />.
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-ink-muted">
        Interactive lessons, calibrated visualizations, and short quizzes
        designed for undergraduate econ and finance courses. Drag a slider,
        watch the curves move, then test yourself.
      </p>
      <div class="mt-8 flex flex-col items-stretch justify-center gap-3 sm:flex-row">
        <a
          href="/eco-1002"
          class="rounded-lg bg-accent px-5 py-3 text-left text-white shadow-sm transition hover:bg-blue-700 sm:min-w-[18rem]"
        >
          <span class="block text-xs uppercase tracking-wide opacity-80">
            Start with ECO 1002:
          </span>
          <span class="mt-0.5 block text-lg font-semibold leading-snug">
            Introduction to Macroeconomics
          </span>
        </a>
        <a
          href="/fin-3610"
          class="rounded-lg border border-slate-300 px-5 py-3 text-left shadow-sm transition hover:border-accent hover:text-accent sm:min-w-[18rem]"
        >
          <span class="block text-xs uppercase tracking-wide text-ink-muted">
            Start with FIN 3610:
          </span>
          <span class="mt-0.5 block text-lg font-semibold leading-snug">
            Corporate Finance
          </span>
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 py-16">
    <h2 class="text-2xl font-semibold">Courses</h2>
    <ul class="mt-6 grid gap-4 md:grid-cols-2">
      {stats.map((c) => (
        <li class="rounded-lg border border-slate-200 bg-white p-5 hover:border-accent transition">
          <a href={c.href} class="block">
            <p class="text-xs uppercase tracking-wide text-accent font-medium">
              {c.code}
            </p>
            <h3 class="mt-1 text-lg font-semibold">{c.title}</h3>
            <p class="mt-1 text-sm text-ink-muted">{c.blurb}</p>
            <p class="mt-3 text-xs text-ink-muted">{c.count} lessons</p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
