---
import BaseLayout from './BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import LessonProgressButton from '@components/lesson/LessonProgressButton';
import FurtherReadingCard from '@components/lesson/FurtherReadingCard.astro';
import { findPrevNext } from '@lib/lesson/sequence';

interface Props {
  lesson: CollectionEntry<'lessons'>;
}
const { lesson } = Astro.props;
const data = lesson.data;

const allLessons = await getCollection('lessons');

// Resolve the "read this next" article: lesson-level frontmatter takes
// priority; otherwise fall back to the matching quiz's article.
let article = data.furtherReading ?? null;
if (!article && data.quizSlug) {
  const quizzes = await getCollection('quizzes');
  const quiz = quizzes.find((q) => q.data.slug === data.quizSlug);
  if (quiz?.data.furtherReading) {
    article = quiz.data.furtherReading;
  }
}

const { prev, next } = findPrevNext(lesson, allLessons);
---
<BaseLayout title={data.title} description={data.summary}>
  <article class="mx-auto max-w-3xl px-4 py-10">
    <p class="text-sm uppercase tracking-wide text-accent font-medium">
      {data.course} · {data.unit}
    </p>
    <h1 class="text-3xl font-semibold tracking-tight mt-2">{data.title}</h1>
    <p class="mt-3 text-ink-muted">{data.summary}</p>

    <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm text-ink-muted">
      <span>⏱ {data.estimatedMinutes} min</span>
      {data.tags.length > 0 && (
        <span>Tags: {data.tags.join(', ')}</span>
      )}
    </div>

    <section class="mt-8 rounded-lg border border-slate-200 bg-slate-50 p-5">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-ink-muted">
        Learning objectives
      </h2>
      <ul class="mt-2 list-disc pl-5 space-y-1">
        {data.learningObjectives.map((o) => <li>{o}</li>)}
      </ul>
    </section>

    <div class="prose mt-10">
      <slot />
    </div>

    {article && <FurtherReadingCard article={article} variant="lesson" />}

    <div class="mt-12 flex flex-wrap items-center justify-between gap-4 border-t border-slate-200 pt-6">
      <LessonProgressButton client:load lessonSlug={lesson.slug} />
      {data.quizSlug && (
        <a
          href={`/practice/${data.quizSlug}`}
          class="rounded bg-accent px-4 py-2 text-white font-medium"
        >
          Practice quiz →
        </a>
      )}
    </div>

    <nav
      class="mt-8 grid gap-3 border-t border-slate-200 pt-6 md:grid-cols-2"
      aria-label="Lesson navigation"
    >
      {prev ? (
        <a
          href={`/lessons/${prev.slug}`}
          class="group flex flex-col rounded-lg border border-slate-200 px-4 py-3 transition hover:border-accent hover:bg-accent/5"
        >
          <span class="text-xs uppercase tracking-wide text-ink-muted group-hover:text-accent">
            ← Previous lesson
          </span>
          <span class="mt-1 font-medium text-ink">{prev.data.title}</span>
        </a>
      ) : (
        <div class="rounded-lg border border-dashed border-slate-200 px-4 py-3 text-sm text-ink-muted">
          You're at the first lesson in this course.
        </div>
      )}
      {next ? (
        <a
          href={`/lessons/${next.slug}`}
          class="group flex flex-col rounded-lg border border-slate-200 px-4 py-3 transition hover:border-accent hover:bg-accent/5 md:items-end md:text-right"
        >
          <span class="text-xs uppercase tracking-wide text-ink-muted group-hover:text-accent">
            Next lesson →
          </span>
          <span class="mt-1 font-medium text-ink">{next.data.title}</span>
        </a>
      ) : (
        <div class="rounded-lg border border-dashed border-slate-200 px-4 py-3 text-right text-sm text-ink-muted">
          You've reached the end of this course.
        </div>
      )}
    </nav>
  </article>
</BaseLayout>
