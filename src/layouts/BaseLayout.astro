---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import CourseSwitcher from '@components/course/CourseSwitcher';
import { listAvailableCourses } from '@lib/dashboard';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Interactive Economics & Finance lessons for undergraduates.' } = Astro.props;
const user = Astro.locals.user;
const profile = Astro.locals.profile;
const supabase = Astro.locals.supabase;

const switcherCourses =
  user && supabase ? await listAvailableCourses(supabase, user.id) : [];
const switcherProps = switcherCourses.map((c) => ({
  slug: c.slug,
  code: c.code,
  title: c.title,
  enrolled: c.enrolled,
}));
const activeCourseSlug = profile?.active_course_slug ?? null;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title} — Baruch Econ & Finance Studio</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto max-w-6xl px-4 py-3 flex items-center justify-between">
        <a href="/" class="font-semibold text-lg tracking-tight">Baruch Econ & Finance Studio</a>
        <nav class="flex items-center gap-4 text-sm">
          <a href="/eco-1002" class="text-ink-muted hover:text-ink">ECO 1002</a>
          <a href="/fin-3610" class="text-ink-muted hover:text-ink">FIN 3610</a>
          {user ? (
            <>
              {switcherProps.length > 0 && (
                <CourseSwitcher
                  client:load
                  courses={switcherProps}
                  activeSlug={activeCourseSlug}
                />
              )}
              <a href="/dashboard" class="text-ink-muted hover:text-ink">Dashboard</a>
              <form method="POST" action="/api/auth/signout" class="inline">
                <button class="text-ink-muted hover:text-ink" type="submit">
                  Sign out
                </button>
              </form>
            </>
          ) : (
            <a class="rounded bg-accent px-3 py-1.5 text-white text-sm" href="/auth/login">
              Sign in
            </a>
          )}
        </nav>
      </div>
    </header>

    <main class="flex-1" transition:animate="fade">
      <slot />
    </main>

    <footer class="border-t border-slate-200 py-8 mt-12 text-sm text-ink-muted">
      <div class="mx-auto max-w-6xl px-4 flex flex-wrap items-center justify-between gap-3">
        <span>© {new Date().getFullYear()} Baruch Econ & Finance Studio</span>
        <nav class="flex gap-4">
          <a href="/privacy" class="hover:text-ink">Privacy</a>
          <a href="/terms" class="hover:text-ink">Terms</a>
          <a href="https://github.com/junbuluv/edu_webpage" class="hover:text-ink">GitHub</a>
        </nav>
        <span>Built with Astro + Supabase</span>
      </div>
    </footer>
  </body>
</html>
